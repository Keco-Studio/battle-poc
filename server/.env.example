# Default upstream for /api/ai/chat and battle when client does not send provider=minimax|deepseek
# deepseek | minimax
# 游戏内聊天 POST /api/agent-chat（默认 CHAT_BACKEND_MODE=deepseek）只读此处与下面的 MINIMAX_* / DEEPSEEK_*。
# 前端的 NEXT_PUBLIC_BATTLE_LLM_PROVIDER 仅影响战斗请求里的 provider，不会改变聊天走哪家模型。
AI_LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 兼容：按量付费密钥通常走 https://api.minimax.io；Token Plan（sk-cp- 开头）需走 https://api.minimaxi.com，否则会 401 / invalid api key (2049)。
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.1
MINIMAX_BASE_URL=https://api.minimax.io

AI_PROXY_PORT=8787
AI_PROXY_ALLOWED_ORIGIN=http://localhost:3000
