# Supabase (same as keco-studio: Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AI chat + battle LLM: run `npm run dev:ai` and copy `server/.env.example` → `server/.env` (gitignored).
# NEXT_PUBLIC_BATTLE_LLM_PROVIDER=minimax
# NEXT_PUBLIC_BATTLE_LLM_MODEL=MiniMax-M2.1
# BATTLE_AI_SERVER_URL=http://127.0.0.1:8787
# NEXT_PUBLIC_BATTLE_AI_SERVER_URL=http://localhost:8787

# dual_llm：浏览器等代理 battle-decision 的最长时间（默认 60000）。设成 12000 时上游常 >12s 会看到 504 This operation was aborted；可先试 16000 或直接用 60000。
# NEXT_PUBLIC_BATTLE_LLM_TIMEOUT_MS=60000

# Server-only admin scripts / Edge; not used in this demo
# SUPABASE_SERVICE_ROLE_KEY=
